# 1) Base image: AWS Lambda Python 3.13
FROM public.ecr.aws/lambda/python:3.13

# 2) Install system deps for lxml and other C-extensions
RUN yum install -y \
      gcc \
      libxml2-devel \
      libxslt-devel \
      openssl-devel \
      && yum clean all

# 3) Copy requirements and install Python deps
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# 4) Copy application code (adjust if your modules live in a subfolder)
COPY app.py ./app.py
COPY metrics ./metrics

# 5) Set the Lambda handler
#   app.lambda_handler => file: app.py, function: lambda_handler
CMD [ "app.lambda_handler" ]
